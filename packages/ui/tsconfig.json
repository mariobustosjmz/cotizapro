{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "ES2020"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/lib/utils": ["src/utils.ts"],
      "@/components/ui/*": ["src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
