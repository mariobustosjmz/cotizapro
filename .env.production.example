# ============================================================
# CotizaPro — Production Environment Variables Template
# ============================================================
# Copy this file to .env.production and fill in real values
# This file IS safe to commit (no secrets)
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (use sk_test_ for sandbox, sk_live_ for production)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...
STRIPE_PRICE_ID_FREE=
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NODE_ENV=production

# Cron protection
CRON_SECRET=random_secret_here
