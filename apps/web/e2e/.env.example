# E2E Test Configuration

# Base URL for tests
BASE_URL=http://localhost:3000

# Test User Credentials
# Create these users in your Supabase instance before running tests
TEST_USER_OWNER_EMAIL=owner@example.com
TEST_USER_OWNER_PASSWORD=TestPassword123!

TEST_USER_ADMIN_EMAIL=admin@example.com
TEST_USER_ADMIN_PASSWORD=TestPassword123!

TEST_USER_MEMBER_EMAIL=member@example.com
TEST_USER_MEMBER_PASSWORD=TestPassword123!

# Stripe Test Keys (for billing tests)
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...
STRIPE_TEST_SECRET_KEY=sk_test_...

# Timeouts (milliseconds)
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=30000
ACTION_TIMEOUT=10000

# Test Execution
HEADLESS=true
SLOW_MO=0
WORKERS=1

# Reporting
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
TRACE_ON_FAILURE=true

# Debugging
DEBUG=false
INSPECTOR=false
